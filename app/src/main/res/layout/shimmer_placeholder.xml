<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    android:background="#E0E0E0">

    <View
        android:id="@+id/shimmer_image"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="#BDBDBD"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/shimmer_name"
        android:layout_width="150dp"
        android:layout_height="20dp"
        android:layout_marginStart="16dp"
        android:background="#BDBDBD"
        app:layout_constraintStart_toEndOf="@id/shimmer_image"
        app:layout_constraintTop_toTopOf="@id/shimmer_image" />

    <View
        android:id="@+id/shimmer_email"
        android:layout_width="200dp"
        android:layout_height="16dp"
        android:layout_marginTop="8dp"
        android:background="#BDBDBD"
        app:layout_constraintStart_toStartOf="@id/shimmer_name"
        app:layout_constraintTop_toBottomOf="@id/shimmer_name" />

    <View
        android:id="@+id/shimmer_status"
        android:layout_width="80dp"
        android:layout_height="16dp"
        android:layout_marginTop="8dp"
        android:background="#BDBDBD"
        app:layout_constraintStart_toStartOf="@id/shimmer_name"
        app:layout_constraintTop_toBottomOf="@id/shimmer_email" />

</androidx.constraintlayout.widget.ConstraintLayout>
